---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { calculateWeightedScore } from '../../utils/calculateWeightedScore';

const mediaPosts = await getCollection('media').catch(() => []);
const posts = [...mediaPosts];
const sortedPosts = posts.sort((a: any, b: any) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout>
  <header class="mb-12 relative w-full lg:w-3/4">
    <h1 class="text-5xl md:text-7xl font-display font-bold text-secondary mb-4 leading-tight">Media</h1>
    <p class="text-xl text-secondary/70">Shows, movies, albums, and random thoughts.</p>
  </header>

  <!-- Filter Bar -->
  <div class="mb-12 flex flex-wrap gap-4 border-b border-outline-variant/30 pb-4">
    <button class="filter-btn active text-sm font-bold uppercase tracking-wider text-primary border-b-2 border-primary pb-1" data-filter="all">All</button>
    <button class="filter-btn text-sm font-bold uppercase tracking-wider text-secondary/50 hover:text-secondary pb-1 transition-colors" data-filter="album">Albums</button>
    <button class="filter-btn text-sm font-bold uppercase tracking-wider text-secondary/50 hover:text-secondary pb-1 transition-colors" data-filter="cinema">Cinema</button>
    <button class="filter-btn text-sm font-bold uppercase tracking-wider text-secondary/50 hover:text-secondary pb-1 transition-colors" data-filter="anime">Anime</button>
  </div>

  <section class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-6">
    {sortedPosts.length > 0 ? sortedPosts.map((post) => {
      const score = calculateWeightedScore(post.data.type, post.data.ratings?.josie || {}, 'josie');

      return (
        <a href={`/media/${post.slug}`} class="post-card group relative flex flex-col gap-3" data-type={post.data.type}>
          <div class="w-full aspect-[2/3] bg-surface-container-low overflow-hidden shadow-sm group-hover:shadow-ambient transition-all duration-300">
            {post.data.image ? (
              <img src={post.data.image} alt={post.data.title} class="w-full h-full object-cover grayscale-[20%] group-hover:grayscale-0 transition-all duration-700 group-hover:scale-105" />
            ) : (
              <div class="w-full h-full flex items-center justify-center bg-surface-container text-secondary/20 font-display font-bold text-xl uppercase tracking-widest text-center p-4">
                No Image
              </div>
            )}
          </div>
          
          <div>
            <h2 class="font-display font-bold text-lg text-secondary group-hover:text-primary transition-colors line-clamp-2">{post.data.title}</h2>
            <p class="text-xs font-sans font-semibold text-secondary/50 uppercase tracking-wider mt-1">{post.data.type}</p>
            
            <div class="flex items-center gap-2 mt-2">
              <span class="text-xs font-bold text-secondary bg-surface-container-highest px-2 py-1 rounded-sm">{score.toFixed(1)}/10</span>
            </div>
          </div>
        </a>
      );
    }) : (
      <div class="col-span-full p-12 border border-outline-variant/30 text-secondary/50 text-lg italic text-center">
        No posts in this category yet.
      </div>
    )}
  </section>
</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const buttons = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.post-card');

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        // Update active states
        buttons.forEach(b => {
          b.classList.remove('active', 'text-primary', 'border-b-2', 'border-primary');
          b.classList.add('text-secondary/50');
        });
        btn.classList.remove('text-secondary/50');
        btn.classList.add('active', 'text-primary', 'border-b-2', 'border-primary');

        const filter = btn.getAttribute('data-filter');

        // Filter cards
        cards.forEach(card => {
          if (filter === 'all' || card.getAttribute('data-type') === filter) {
            (card as HTMLElement).style.display = 'flex';
          } else {
            (card as HTMLElement).style.display = 'none';
          }
        });
      });
    });
  });
</script>
